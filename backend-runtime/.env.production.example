# Production — Centre Medical AMEN (backend)
APP_NAME="Centre Medical AMEN"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://amen.votredomaine.cd

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amen_production
DB_USERNAME=amen_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.votredomaine.cd

QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.votredomaine.cd
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@amen.cd"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=amen.votredomaine.cd

# Integrations production
FCM_ENABLED=true
FCM_SERVER_KEY=

AT_ENABLED=true
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=AMEN

JITSI_DOMAIN=meet.jit.si
JITSI_ROOM_PREFIX=amen-rdv

MOBILE_MONEY_MOCK=false
AIRTEL_MONEY_ENABLED=true
MPESA_ENABLED=true
